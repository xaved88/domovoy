{
  "permissions": {
    "allow": [
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git stash *)",
      "Bash(git reset *)",
      "Bash(git restore *)",
      "Bash(git rm *)",
      "Bash(git show *)",
      "Bash(git tag *)",
      "Bash(git init *)",
      "Bash(yarn *)",
      "Bash(node *)",
      "Bash(docker *)",
      "Bash(docker compose *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "if": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "yarn tsc --noEmit",
            "timeout": 60,
            "statusMessage": "Type-checking before commit..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{const i=JSON.parse(d);const f=i.tool_input&&i.tool_input.file_path||i.tool_response&&i.tool_response.filePath||'';if(f)require('child_process').execSync('yarn lint --fix \"'+f+'\"',{stdio:'inherit'});});\" 2>/dev/null || true",
            "timeout": 30,
            "statusMessage": "Linting..."
          }
        ]
      }
    ]
  }
}
